{
  "name": "worldcup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "start": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "deploy": "npm run build && wrangler pages deploy dist --project-name worldcup2026",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "normalize-data": "tsx scripts/normalize-tournament-data.ts",
    "update-results": "tsx scripts/update-results.ts",
    "update-stats": "tsx scripts/update-stats.ts",
    "index-scenarios": "tsx scripts/index-scenarios.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "wrangler": "^4.102.0"
  }
}
